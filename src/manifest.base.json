{
  "manifest_version": 3,
  "name": "SecurePaid VPN",
  "short_name": "SecurePaid VPN",
  "version": "1.0.0",
  "description": "Browser-only VPN by SecurePaid VPN. Active subscription required.",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; base-uri 'self'; frame-ancestors 'none'"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "SecurePaid VPN",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "permissions": [
    "storage",
    "proxy",
    "alarms",
    "webRequest",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
